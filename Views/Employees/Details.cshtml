@model IT15_LabExam_Bais.Models.EmployeeDetailsViewModel

@{
    ViewData["Title"] = "Employee Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Employee Details</h1>
    <a asp-controller="Payroll" asp-action="Create" asp-route-employeeId="@Model.Employee.Id" class="btn btn-primary">Add Payroll</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Employee ID</dt>
            <dd class="col-sm-9">@Model.Employee.Id</dd>

            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@Model.Employee.FirstName</dd>

            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@Model.Employee.LastName</dd>

            <dt class="col-sm-3">Position</dt>
            <dd class="col-sm-9">@Model.Employee.Position</dd>

            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">@Model.Employee.Department</dd>

            <dt class="col-sm-3">Daily Rate</dt>
            <dd class="col-sm-9">@Model.Employee.DailyRate.ToString("N2")</dd>
        </dl>
    </div>
</div>

<h2 class="h5">Payroll History</h2>
<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Days Worked</th>
                <th>Gross Pay</th>
                <th>Deduction</th>
                <th>Net Pay</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.PayrollHistory.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-3">No payroll records found for this employee.</td>
                </tr>
            }
            else
            {
                @foreach (var payroll in Model.PayrollHistory)
                {
                    <tr>
                        <td>@payroll.Date.ToString("yyyy-MM-dd")</td>
                        <td>@payroll.DaysWorked</td>
                        <td>@payroll.GrossPay.ToString("N2")</td>
                        <td>@payroll.Deduction.ToString("N2")</td>
                        <td>@payroll.NetPay.ToString("N2")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="d-flex gap-2 mt-3">
    <a asp-controller="Payroll" asp-action="Index" asp-route-employeeId="@Model.Employee.Id" class="btn btn-outline-primary">Open Payroll Module</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Employees</a>
</div>
