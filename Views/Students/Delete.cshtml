@model IT15_LabExam_Bais.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<h1 class="h3 text-danger">Delete Student</h1>
<p>Are you sure you want to delete this student record?</p>

<div class="card border-danger mb-3">
    <div class="card-body">
        <h5 class="card-title mb-3">@Model.FullName</h5>
        <p class="card-text mb-1"><strong>Student Number:</strong> @Model.StudentNumber</p>
        <p class="card-text mb-1"><strong>Email:</strong> @Model.Email</p>
        <p class="card-text mb-0"><strong>Course:</strong> @Model.Course</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
