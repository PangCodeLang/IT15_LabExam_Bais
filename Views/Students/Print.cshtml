@model List<IT15_LabExam_Bais.Models.Student>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Student List Print</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 24px;
        }

        h1 {
            margin-bottom: 16px;
            font-size: 22px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: left;
            font-size: 12px;
        }

        th {
            background-color: #f4f4f4;
        }

        .print-actions {
            margin-bottom: 12px;
        }

        @@media print {
            .print-actions {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="print-actions">
        <button onclick="window.print()">Print</button>
    </div>

    <h1>Student Management System - Student List</h1>
    <table>
        <thead>
            <tr>
                <th>Student No.</th>
                <th>Name</th>
                <th>Email</th>
                <th>Course</th>
                <th>Year</th>
                <th>Birth Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.StudentNumber</td>
                    <td>@student.FullName</td>
                    <td>@student.Email</td>
                    <td>@student.Course</td>
                    <td>@student.YearLevel</td>
                    <td>@student.BirthDate.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
