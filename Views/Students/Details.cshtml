@model IT15_LabExam_Bais.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<h1 class="h3">Student Details</h1>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Student Number</dt>
            <dd class="col-sm-9">@Model.StudentNumber</dd>

            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Course</dt>
            <dd class="col-sm-9">@Model.Course</dd>

            <dt class="col-sm-3">Year Level</dt>
            <dd class="col-sm-9">@Model.YearLevel</dd>

            <dt class="col-sm-3">Birth Date</dt>
            <dd class="col-sm-9">@Model.BirthDate.ToString("MMMM dd, yyyy")</dd>
        </dl>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    }
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>
