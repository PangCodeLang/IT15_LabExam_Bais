@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center py-5">
    <h1 class="display-5 fw-bold">Employee and Payroll System</h1>
    <p class="lead">Manage employee records and payroll transactions with automatic salary computation.</p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Employees" asp-action="Index" class="btn btn-primary btn-lg mt-2">Open System</a>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg mt-2">Login to Continue</a>
        <p class="mt-3 mb-0 text-muted">Default admin: admin@it15.local / Admin#123</p>
        <p class="mb-0 text-muted">Default staff: staff@it15.local / Staff#123</p>
    }
</div>
