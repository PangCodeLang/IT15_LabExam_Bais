@model List<IT15_LabExam_Bais.Models.UserListItemViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Manage Users</h1>
    <a asp-action="Register" class="btn btn-primary">Create User</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Email</th>
                <th>Role</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td class="text-end">
                        <a asp-action="EditUserRole" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary">Edit Role</a>
                        <a asp-action="ResetPassword" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-warning">Reset Password</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
